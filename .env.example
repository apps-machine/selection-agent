# Anthropic API key for LLM judges (text + vision). Optional for `demo` and `scan --no-llm`.
ANTHROPIC_API_KEY=

# Optional: override Claude model IDs.
# ANTHROPIC_TEXT_JUDGE_MODEL=claude-sonnet-4-6
# ANTHROPIC_VISION_JUDGE_MODEL=claude-sonnet-4-6

# Optional: log level (debug, info, warn, error).
# LOG_LEVEL=info

# Optional: SQLite database path. Defaults to ./.cache/selection-agent.sqlite
# SELECTION_AGENT_DB=./.cache/selection-agent.sqlite
